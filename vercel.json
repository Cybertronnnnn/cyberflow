{
  "version": 2,
  "functions": {
    "api/**/*.js": {
      "memory": 256,
      "maxDuration": 30
    },
    "payment/**/*.js": {
      "memory": 256,
      "maxDuration": 30
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/payment/(.*)", "dest": "/payment/$1" },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ]
}
